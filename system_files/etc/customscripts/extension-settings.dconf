[advanced-alt-tab-window-switcher]
animation-time-factor=100
enable-super=true
hot-edge-mode=1
hot-edge-position=1
show-dash=1
super-double-press-action=3
super-key-mode=3
switcher-popup-theme=3
switcher-popup-up-down-action=4
switcher-ws-thumbnails=1

[alphabetical-app-grid]
folder-order-position='end'

[appindicator]
compact-mode-enabled=false
custom-icons=@a(sss) []
icon-brightness=0.0
icon-contrast=0.0
icon-opacity=240
icon-saturation=0.0
icon-size=0
legacy-tray-enabled=false
tray-pos='right'

[blur-my-shell]
rounded-blur-found=false
settings-version=2

[blur-my-shell/appfolder]
brightness=0.59999999999999998
sigma=30

[blur-my-shell/applications]
pipeline='pipeline_default'

[blur-my-shell/coverflow-alt-tab]
pipeline='pipeline_default'

[blur-my-shell/dash-to-dock]
blur=false
brightness=0.59999999999999998
override-background=true
pipeline='pipeline_default_rounded'
sigma=30
static-blur=true
style-dash-to-dock=0

[blur-my-shell/lockscreen]
pipeline='pipeline_default'

[blur-my-shell/overview]
pipeline='pipeline_default'

[blur-my-shell/panel]
blur=true
brightness=0.59999999999999998
corner-radius=0
force-light-text=true
pipeline='pipeline_default'
sigma=30
static-blur=false

[blur-my-shell/screenshot]
pipeline='pipeline_default'

[blur-my-shell/window-list]
brightness=0.59999999999999998
sigma=30

[caffeine]
cli-toggle=false
indicator-position-max=2
user-enabled=true

[clipboard-indicator]
blink-icon-on-copy=true
clear-history-interval=1440
clear-history-on-interval=true
clear-on-boot=true
disable-down-arrow=true
display-mode=0
excluded-apps=['1password']
next-history-clear=1782805789
open-at-cursor=true
paste-on-select=true
strip-text=true
toggle-menu=['<Super>v']

