menuicon-setting='org.gnome.Settings-symbolic'
menulocation-setting=1
menuoptions-setting=2

[custom-command-toggle]
buttonclick1-setting=2
checkcommandsync1-setting=false
checkexitcode1-setting=false
closemenu1-setting=true
entryrow1-setting='gnome-control-center system about'
entryrow2-setting=''
entryrow3-setting='About'
entryrow4-setting='help-about-symbolic'
force-refresh=true
initialtogglestate1-setting=1
numbuttons-setting=2
showindicator1-setting=false
togglestate1-setting=false
togglestate2-setting=false

[dash-to-dock]
always-center-icons=true
apply-custom-theme=false
autohide=true
background-color='rgb(154,153,150)'
background-opacity=0.29999999999999999
click-action='previews'
custom-background-color=true
custom-theme-shrink=false
customize-alphas=false
dash-max-icon-size=40
dock-fixed=true
dock-position='BOTTOM'
extend-height=false
height-fraction=0.90000000000000002
hot-keys=true
hotkeys-overlay=true
hotkeys-show-dock=true
intellihide=true
intellihide-mode='FOCUS_APPLICATION_WINDOWS'
max-alpha=0.80000000000000004
preferred-monitor=-2
preferred-monitor-by-connector='eDP-1'
pressure-threshold=50.0
running-indicator-style='DOT'
shortcut=['<Super>r']
shortcut-text='<Super>r'
shortcut-timeout=2.0
show-apps-always-in-the-edge=true
transparency-mode='FIXED'

[gsconnect]
enabled=true
keep-alive-when-locked=true

[gsconnect/preferences]
window-maximized=false
window-size=(640, 550)

[hotedge]
fallback-in-use=false
show-animation=false

[just-perfection]
activities-button=true
dash-app-running=false
events-button=false
support-notifier-showed-version=36

[libpanel]
alignment='right'
layout=[['gnome@main', 'quick-settings-audio-panel@rayzeq.github.io/main']]
single-column=false

[nightthemeswitcher/time]
location=(50.900727669070911, 5.4187500000000002)
manual-schedule=true
nightthemeswitcher-ondemand-keybinding=['<Shift><Super>t']
sunrise=7.0
sunset=20.0

[quick-settings-audio-panel]
add-button-applications-output-reset-to-default=true
always-show-input-volume-slider=false
create-applications-volume-sliders=true
create-balance-slider=false
create-mpris-controllers=true
create-perdevice-volume-sliders=false
create-profile-switcher=false
group-applications-volume-sliders=false
master-volume-sliders-show-current-device=false
merged-panel-position='bottom'
move-input-volume-slider=true
move-output-volume-slider=true
mpris-controllers-are-moved=true
panel-type='independent-panel'
perdevice-volume-sliders-change-menu=true
profiles-renames={'Radeon High Definition Audio Controller': {'off': ('Off', 'Off'), 'pro-audio': ('Pro Audio', 'Pro Audio'), 'HiFi': ('Play HiFi quality Music', 'Play HiFi quality Music')}, 'Ryzen HD Audio Controller': {'off': ('Off', 'Off'), 'pro-audio': ('Pro Audio', 'Pro Audio'), 'HiFi (Mic1, Mic2, Speaker)': ('Play HiFi quality Music (Mic1, Mic2, Speaker)', 'Play HiFi quality Music (Mic1, Mic2, Speaker)'), 'HiFi (Headphones, Mic1, Mic2)': ('Play HiFi quality Music (Headphones, Mic1, Mic2)', 'Play HiFi quality Music (Headphones, Mic1, Mic2)'), 'HiFi (Headset, Mic1, Speaker)': ('Play HiFi quality Music (Headset, Mic1, Speaker)', 'Play HiFi quality Music (Headset, Mic1, Speaker)'), 'HiFi (Headphones, Headset, Mic1)': ('Play HiFi quality Music (Headphones, Headset, Mic1)', 'Play HiFi quality Music (Headphones, Headset, Mic1)')}, 'Studio Display': {'off': ('Off', 'Off'), 'input:mono-fallback': ('Mono Input', 'Mono Input'), 'pro-audio': ('Pro Audio', 'Pro Audio'), 'output:iec958-stereo': ('Digital Stereo (IEC958) Output', 'Digital Stereo (IEC958) Output'), 'output:iec958-stereo+input:mono-fallback': ('Digital Stereo (IEC958) Output + Mono Input', 'Digital Stereo (IEC958) Output + Mono Input'), 'output:analog-stereo': ('Analog Stereo Output', 'Analog Stereo Output'), 'output:analog-stereo+input:mono-fallback': ('Analog Stereo Output + Mono Input', 'Analog Stereo Output + Mono Input')}}
remove-output-volume-slider=false
version=2
widgets-order=['profile-switcher', 'mpris-controllers', 'output-volume-slider', 'perdevice-volume-sliders', 'input-volume-slider', 'balance-slider', 'applications-volume-sliders']

[restartto]
blacklist=['Fedora', 'EFI USB Device', 'EFI Network', 'EFI DVD/CDROM']

[search-light]
animation-speed=100.0
blur-background=false
blur-brightness=0.59999999999999998
blur-sigma=30.0
border-color=(0.0, 0.0, 0.0, 1.0)
border-radius=1.7657657657657655
entry-font-size=1
monitor-count=1
panel-icon-color=(0.0, 0.0, 0.0, 1.0)
preferred-monitor=0
scale-height=0.10000000000000001
scale-width=0.10000000000000001
secondary-shortcut-search=['<Super>space']
shortcut-search=['<Control>space']
show-panel-icon=true
window-effect=0
window-effect-color=(0.0, 0.0, 0.0, 1.0)

[tiling-assistant]
focus-hint-color='rgb(53,132,228)'
last-version-installed=54
overridden-settings={'org.gnome.mutter.edge-tiling': <@mb nothing>, 'org.gnome.desktop.wm.keybindings.maximize': <@mb nothing>, 'org.gnome.desktop.wm.keybindings.unmaximize': <@mb nothing>, 'org.gnome.mutter.keybindings.toggle-tiled-left': <@mb nothing>, 'org.gnome.mutter.keybindings.toggle-tiled-right': <@mb nothing>}
